{
  "name": "revit-mcp-next-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Clean-room, token-efficient Revit MCP bridge for Claude Code and Codex.",
  "workspaces": [
    "contracts",
    "broker"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:addin": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-addin.ps1",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "install:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File installer/install-windows.ps1"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "license": "MIT"
}
