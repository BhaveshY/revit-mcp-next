{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/BhaveshY/revit-mcp-next/contracts/bridge-envelope.schema.json",
  "title": "Revit MCP Next Bridge Envelope",
  "type": "object",
  "required": ["protocolVersion", "requestId", "sessionId", "operation", "operationKind", "timeoutMs", "payload"],
  "properties": {
    "protocolVersion": { "const": "2026-06-22" },
    "requestId": { "type": "string", "minLength": 1 },
    "sessionId": { "type": "string", "minLength": 1 },
    "operation": { "type": "string", "minLength": 1 },
    "operationKind": { "enum": ["read", "preview", "write", "destructive", "debug"] },
    "timeoutMs": { "type": "integer", "minimum": 1 },
    "documentFingerprint": { "type": "string" },
    "expectedGeneration": { "type": "integer", "minimum": 0 },
    "payload": {}
  },
  "additionalProperties": false
}

